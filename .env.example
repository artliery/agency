# Core
DEBUG=False
ALLOWED_HOSTS=.onrender.com,artliery.com,www.artliery.com
CSRF_TRUSTED_ORIGINS=https://agency-uhnz.onrender.com,https://artliery.com,https://www.artliery.com
TIME_ZONE=Asia/Dhaka
DEMO_MODE=False

# Make the WHITENOISE_CONFIG=True for production server
WHITENOISE_CONFIG=True

# Cloudinary media storage (required for persistent uploads on Render)
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# If you make this POSTGRE_DB or MYSQL_DB to False the system will use DBSQLITE by default
POSTGRE_DB=True
MYSQL_DB=False

# Preferred on Render: set DATABASE_URL directly from Render Postgres
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Optional explicit DB vars (used when DATABASE_URL is not provided)
DB_NAME=database_name
DB_USER=database_user
DB_PASSWORD=database_password
DB_HOST=database_host
# DB_PORT = 3306 for MYSQL || 5432 for Postgres
DB_PORT=5432

# Email Credentials
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=example@gmail.com
EMAIL_HOST_PASSWORD=host_password

# Media Setup Path If Using in Another Domain
MEDIA_ROOT=/home/cpanel_username/domain.com/media

# Media Setup Path If Using in Primary Domain
MEDIA_ROOT=/home/cpanel_username/public_html/media